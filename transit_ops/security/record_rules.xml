<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Driver Rule: Can only see trips assigned to them -->
        <record id="rule_transitops_trip_driver_own" model="ir.rule">
            <field name="name">TransitOps Trip: Driver Own Trips Only</field>
            <field name="model_id" ref="model_transitops_trip"/>
            <field name="domain_force">[('driver_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_transitops_driver'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Rule for Fleet Manager / Safety Officer / Financial Analyst to see all trips -->
        <record id="rule_transitops_trip_all" model="ir.rule">
            <field name="name">TransitOps Trip: View All Trips</field>
            <field name="model_id" ref="model_transitops_trip"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_transitops_fleet_manager')), (4, ref('group_transitops_safety_officer')), (4, ref('group_transitops_financial_analyst'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
