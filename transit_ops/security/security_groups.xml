<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Module Category -->
        <record id="module_category_transit_ops" model="ir.module.category">
            <field name="name">TransitOps</field>
            <field name="description">Access levels for TransitOps transport operations platform.</field>
            <field name="sequence">25</field>
        </record>

        <!-- Driver Group -->
        <record id="group_transitops_driver" model="res.groups">
            <field name="name">Driver</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Safety Officer Group -->
        <record id="group_transitops_safety_officer" model="res.groups">
            <field name="name">Safety Officer</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Financial Analyst Group -->
        <record id="group_transitops_financial_analyst" model="res.groups">
            <field name="name">Financial Analyst</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Fleet Manager Group -->
        <record id="group_transitops_fleet_manager" model="res.groups">
            <field name="name">Fleet Manager</field>
            <field name="category_id" ref="module_category_transit_ops"/>
            <field name="implied_ids" eval="[(4, ref('group_transitops_financial_analyst')), (4, ref('group_transitops_safety_officer'))]"/>
        </record>
    </data>
</odoo>
