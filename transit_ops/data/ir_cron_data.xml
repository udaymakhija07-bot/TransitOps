<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Daily Cron Scheduler for License Expiry Alert -->
        <record id="ir_cron_check_license_expiry" model="ir.cron">
            <field name="name">TransitOps: Daily Driver License Expiry Check</field>
            <field name="model_id" ref="model_transitops_driver"/>
            <field name="state">code</field>
            <field name="code">model.check_license_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
