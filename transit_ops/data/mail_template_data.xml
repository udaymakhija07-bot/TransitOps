<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="email_template_driver_license_expiry" model="mail.template">
            <field name="name">Driver License Expiry Compliance Alert</field>
            <field name="model_id" ref="transit_ops.model_transitops_driver"/>
            <field name="subject">TransitOps Compliance Alert: Driver License Expiring Soon</field>
            <field name="email_from">{{ object.env.user.email_formatted or 'noreply@transitops.com' }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;">
                    <table style="width: 100%; border-collapse: collapse; background-color: #f8fafc; padding: 30px;">
                        <tr>
                            <td align="center">
                                <table style="width: 600px; border-collapse: collapse; background-color: #ffffff; border: 1px solid #e2e8f0; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
                                    <!-- Header -->
                                    <tr style="background-gradient: linear-gradient(to right, #4f46e5, #6366f1); background-color: #4f46e5; color: #ffffff;">
                                        <td style="padding: 24px; text-align: center; font-size: 20px; font-weight: bold; letter-spacing: 0.5px;">
                                            TransitOps Compliance Alert
                                        </td>
                                    </tr>
                                    <!-- Body -->
                                    <tr>
                                        <td style="padding: 32px; color: #334155; font-size: 15px; line-height: 1.6;">
                                            <p style="margin-top: 0;">Dear Safety Team,</p>
                                            <p>This is an automated notification that the driving license of driver <strong><t t-out="object.name"/></strong> is nearing its expiration date.</p>
                                            
                                            <table style="width: 100%; margin: 24px 0; border-collapse: collapse; border: 1px solid #f1f5f9; border-radius: 6px; overflow: hidden;">
                                                <tr style="background-color: #f8fafc;">
                                                    <td style="padding: 12px; font-weight: bold; border-bottom: 1px solid #f1f5f9; width: 180px;">Driver Name:</td>
                                                    <td style="padding: 12px; border-bottom: 1px solid #f1f5f9;"><t t-out="object.name"/></td>
                                                </tr>
                                                <tr>
                                                    <td style="padding: 12px; font-weight: bold; border-bottom: 1px solid #f1f5f9;">License Number:</td>
                                                    <td style="padding: 12px; border-bottom: 1px solid #f1f5f9;"><t t-out="object.license_number"/></td>
                                                </tr>
                                                <tr style="background-color: #f8fafc;">
                                                    <td style="padding: 12px; font-weight: bold; border-bottom: 1px solid #f1f5f9;">Category:</td>
                                                    <td style="padding: 12px; border-bottom: 1px solid #f1f5f9;"><t t-out="object.license_category or 'N/A'"/></td>
                                                </tr>
                                                <tr>
                                                    <td style="padding: 12px; font-weight: bold; color: #e11d48;">Expiry Date:</td>
                                                    <td style="padding: 12px; font-weight: bold; color: #e11d48;"><t t-out="object.license_expiry_date"/></td>
                                                </tr>
                                            </table>

                                            <p>Please review and verify driver credentials in the TransitOps Platform as soon as possible to ensure operational continuity.</p>
                                        </td>
                                    </tr>
                                    <!-- Footer -->
                                    <tr style="background-color: #f8fafc; border-top: 1px solid #e2e8f0; text-align: center;">
                                        <td style="padding: 16px; font-size: 12px; color: #64748b;">
                                            This is an automated system email. Please do not reply directly.
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>
                </div>
            </field>
        </record>
    </data>
</odoo>
